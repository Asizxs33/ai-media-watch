{
  "manifest_version": 3,
  "name": "Spectra AI — Защита от мошенничества",
  "version": "1.0.0",
  "description": "Обнаруживает мошеннический контент в YouTube, TikTok и Instagram. Самоконтроль времени.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://*.tiktok.com/*",
    "https://*.instagram.com/*",
    "http://localhost:3001/*",
    "https://*.trycloudflare.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content/shared.js", "content/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.tiktok.com/*"],
      "js": ["content/shared.js", "content/tiktok.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.instagram.com/*"],
      "js": ["content/shared.js", "content/instagram.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
